#!/usr/bin/env python3
import json
import sys
import urllib.request
from urllib.error import URLError, HTTPError

BASE_URL = sys.argv[1] if len(sys.argv) > 1 else 'http://127.0.0.1:3012'
checks = [
  ('health', f'{BASE_URL}/api/health'),
  ('status', f'{BASE_URL}/api/hesap-merkezi/status'),
  ('page', f'{BASE_URL}/hesap-merkezi'),
]

result = {'ok': True, 'baseUrl': BASE_URL, 'checks': {}}

for key, url in checks:
  try:
    with urllib.request.urlopen(url, timeout=10) as response:
      body = response.read().decode('utf-8', 'ignore')
      entry = {'status': response.status}
      if key == 'status':
        payload = json.loads(body)
        entry.update({
          'profiles': payload['state']['totalProfiles'],
          'current': payload['state']['currentDisplayName'],
          'hasAuthSession': bool(payload['authSession']),
        })
      elif key == 'page':
        entry.update({'hasHesapMerkezi': 'Hesap Merkezi' in body})
      else:
        entry.update({'body': body})
      result['checks'][key] = entry
  except (URLError, HTTPError, TimeoutError, json.JSONDecodeError) as error:
    result['ok'] = False
    result['checks'][key] = {'error': repr(error)}

print(json.dumps(result, ensure_ascii=False, indent=2))
sys.exit(0 if result['ok'] else 1)
